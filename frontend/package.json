{
  "name": "assistgen-frontend",
  "version": "1.0.0",
  "description": "AssistGen Intelligent Customer Service - Frontend Application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test:unit": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^10.11.1",
    "axios": "^1.7.9",
    "dompurify": "^3.2.3",
    "markdown-it": "^14.1.0",
    "marked": "^15.0.6",
    "pinia": "^2.3.1",
    "vue": "^3.4.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.8",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
