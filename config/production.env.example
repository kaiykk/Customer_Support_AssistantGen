# Production Environment Configuration
# Copy this file to .env and update with your actual production values
# IMPORTANT: Never commit actual .env files to version control!

# ============================================================================
# LLM Service Configuration
# ============================================================================

CHAT_SERVICE=deepseek
REASON_SERVICE=deepseek
AGENT_SERVICE=deepseek

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your-production-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Vision Model Configuration
VISION_API_KEY=your-production-vision-api-key
VISION_BASE_URL=https://api.deepseek.com/v1
VISION_MODEL=deepseek-vl

# Ollama Configuration (if using local models)
OLLAMA_BASE_URL=http://ollama-service:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_REASON_MODEL=deepseek-r1:7b
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_AGENT_MODEL=qwen2.5:7b

# ============================================================================
# Database Configuration
# ============================================================================

# MySQL Database
DB_HOST=mysql-prod.example.com
DB_PORT=3306
DB_USER=assistgen_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=assistgen_production

# Neo4j Graph Database
NEO4J_URL=bolt://neo4j-prod.example.com:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD
NEO4J_DATABASE=neo4j

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_HOST=redis-prod.example.com
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.8

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret Key (MUST be a strong random string in production)
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# Search Configuration
# ============================================================================

SERPAPI_KEY=your-production-serpapi-key
SEARCH_RESULT_COUNT=3

# ============================================================================
# Embedding Configuration
# ============================================================================

EMBEDDING_TYPE=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_THRESHOLD=0.90

# ============================================================================
# GraphRAG Configuration
# ============================================================================

GRAPHRAG_PROJECT_DIR=backend/app/graphrag
GRAPHRAG_DATA_DIR=data
GRAPHRAG_QUERY_TYPE=local
GRAPHRAG_RESPONSE_TYPE=text
GRAPHRAG_COMMUNITY_LEVEL=3
GRAPHRAG_DYNAMIC_COMMUNITY=false

# ============================================================================
# Application Configuration
# ============================================================================

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=false

# CORS Configuration (specify your production domains)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/assistgen_prod.log

# ============================================================================
# Monitoring and Performance
# ============================================================================

# Enable performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
